{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 6am on monday"],
  "postUpdateOptions": ["gomodTidy"],
  "packageRules": [
    {
      "description": "Kubernetes libraries must be upgraded in lockstep (k8s.io/* and the controller-runtime/tools that track them), so group them into a single PR.",
      "groupName": "kubernetes packages",
      "matchManagers": ["gomod"],
      "matchPackageNames": [
        "k8s.io/**",
        "sigs.k8s.io/controller-runtime",
        "sigs.k8s.io/controller-tools"
      ]
    },
    {
      "description": "Automerge low-risk Go module updates once CI passes.",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Automerge GitHub Actions and base-image digest/minor/patch bumps.",
      "matchManagers": ["github-actions", "dockerfile"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Major upgrades always get a reviewed PR, never automerged.",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update"]
    }
  ]
}
